# ===================================================
# Student Internal Marks Assessment Portal
# Environment Variables Template
# ===================================================

# --- Server ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=student_marks_portal
DB_USER=root
DB_PASSWORD=your_mysql_password

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=30d

# --- Firebase ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_FIREBASE_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# --- Firebase Client (for frontend) ---
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=student-marks-portal-files
AWS_SES_FROM_EMAIL=noreply@yourcollegedomain.edu
AWS_CLOUDFRONT_URL=https://your-distribution.cloudfront.net

# --- RDS (Production) ---
RDS_HOST=your-rds-endpoint.rds.amazonaws.com
RDS_PORT=3306
RDS_DB_NAME=student_marks_portal
RDS_USERNAME=admin
RDS_PASSWORD=your_rds_password

# --- Elastic Beanstalk ---
EB_ENVIRONMENT=student-marks-portal-prod
EB_APPLICATION=student-marks-portal

# --- App Config ---
BCRYPT_SALT_ROUNDS=12
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=xlsx,csv,pdf
SESSION_SECRET=your_session_secret_key

# --- Email Templates ---
COLLEGE_NAME=Government Engineering College
COLLEGE_LOGO_URL=https://your-cloudfront-url/logo.png
SUPPORT_EMAIL=support@yourcollegedomain.edu
